# Supabase (mesma instância da Minds OU nova — escolher)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Resend
RESEND_API_KEY=
EMAIL_FROM="Team Manager <noreply@teammanager.app>"

# Calendly link do founder (opcional — usado no CTA pós-quiz)
NEXT_PUBLIC_DEMO_CALENDLY=

# Domínio público (usado em emails como link de retorno)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# WAHA (mesma stack do Team Manager SaaS) — checa se o número do lead tem
# WhatsApp ativo antes de aceitar o envio. Sem essas vars, a checagem é
# pulada (a validação de formato do celular ainda roda).
WAHA_API_URL=
WAHA_API_KEY=
WAHA_SESSION=

# Webhook de notificação de novo lead
# Cola URL do Discord, Slack, Make, Zapier, n8n, ou endpoint próprio.
# - Discord: https://discord.com/api/webhooks/{ID}/{TOKEN}
# - Slack:   https://hooks.slack.com/services/T.../B.../...
# - Genérico: qualquer URL que aceite POST JSON
LEAD_WEBHOOK_URL=

# Meta Pixel + Conversions API (CAPI) para tráfego pago
# NEXT_PUBLIC_META_PIXEL_ID: ID do pixel (Gerenciador de Eventos do Meta)
# META_CAPI_ACCESS_TOKEN: token da Conversions API do mesmo pixel
# Sem essas, o pixel não carrega e o CAPI é pulado (degradação graciosa).
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Microsoft Clarity (heatmap + gravação de sessão)
# NEXT_PUBLIC_CLARITY_ID: Project ID em clarity.microsoft.com > Settings > Setup
# Sem essa var, o script não carrega.
NEXT_PUBLIC_CLARITY_ID=
