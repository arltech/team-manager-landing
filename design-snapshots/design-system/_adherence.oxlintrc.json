{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/buttons/**",
              "components/content/**",
              "components/forms/**",
              "components/primitives/**",
              "ui_kits/landing/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Inter|Manrope))/i]",
        "message": "Font not provided by the design system. Available: Inter, Manrope."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute > JSXIdentifier[name!=/^(?:summary|children|variant|defaultOpen|className|style|key|ref|className|style|children)$/]",
        "message": "<Accordion> doesn't accept that prop. Declared props: summary, children, variant, defaultOpen, className, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Accordion'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:card|subtle)$/]",
        "message": "<Accordion> variant must be one of 'card' | 'subtle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|size|ring|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, name, size, ring."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|icon|count|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, icon, count, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|success|destructive|warning|neutral)$/]",
        "message": "<Badge> tone must be one of 'primary' | 'success' | 'destructive' | 'warning' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|icon|iconRight|disabled|fullWidth|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, icon, iconRight, disabled, fullWidth, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|white)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'white'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:featured|hover|padding|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: featured, hover, padding, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconBadge'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|tone|children|key|ref|className|style|children)$/]",
        "message": "<IconBadge> doesn't accept that prop. Declared props: size, tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconBadge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<IconBadge> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconBadge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|success|destructive|warning|accent|neutral)$/]",
        "message": "<IconBadge> tone must be one of 'primary' | 'success' | 'destructive' | 'warning' | 'accent' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|size|wrapperStyle|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: icon, size, wrapperStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Input> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|value|sub|delta|variant|key|ref|className|style|children)$/]",
        "message": "<KpiCard> doesn't accept that prop. Declared props: icon, label, value, sub, delta, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='KpiCard'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<KpiCard> variant must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|children|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: tone, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:primary|success|destructive|accent|muted|dark-glass|solid-primary)$/]",
        "message": "<Pill> tone must be one of 'primary' | 'success' | 'destructive' | 'accent' | 'muted' | 'dark-glass' | 'solid-primary'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:pill|pillTone|title|subtitle|align|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: pill, pillTone, title, subtitle, align."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='pillTone'] > Literal[value!=/^(?:primary|success|destructive|accent|muted)$/]",
        "message": "<SectionHeader> pillTone must be one of 'primary' | 'success' | 'destructive' | 'accent' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeader> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "x-omelette": {
